<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="23504" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" launchScreen="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="ipad11_0" orientation="portrait" layout="fullscreen" appearance="light"/>
    <dependencies>
        <deployment identifier="iOS"/>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23506"/>
    </dependencies>
    <scenes>
        <scene sceneID="LaunchScene">
            <objects>
                <viewController id="LaunchViewController" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="LaunchView">
                        <rect key="frame" x="0.0" y="0.0" width="834" height="1194"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <imageView contentMode="scaleAspectFit" image="LaunchIcon" translatesAutoresizingMaskIntoConstraints="NO" id="IconView">
                                <constraints>
                                    <constraint firstAttribute="width" constant="140"/>
                                    <constraint firstAttribute="height" constant="140"/>
                                </constraints>
                            </imageView>
                            <label opaque="NO" text="lightPad" textAlignment="center" translatesAutoresizingMaskIntoConstraints="NO" id="TitleLabel">
                                <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="30"/>
                                <color key="textColor" red="1" green="1" blue="1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            </label>
                            <label opaque="NO" text="Film viewing lightbox" textAlignment="center" translatesAutoresizingMaskIntoConstraints="NO" id="SubtitleLabel">
                                <fontDescription key="fontDescription" type="system" weight="regular" pointSize="15"/>
                                <color key="textColor" red="1" green="1" blue="1" alpha="0.7" colorSpace="custom" customColorSpace="sRGB"/>
                            </label>
                            <label opaque="NO" text="© 2026 Anand Mandapati" textAlignment="center" translatesAutoresizingMaskIntoConstraints="NO" id="CopyrightLabel">
                                <fontDescription key="fontDescription" type="system" weight="regular" pointSize="12"/>
                                <color key="textColor" red="1" green="1" blue="1" alpha="0.6" colorSpace="custom" customColorSpace="sRGB"/>
                            </label>
                        </subviews>
                        <color key="backgroundColor" red="0.0" green="0.0" blue="0.0" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <constraint firstItem="IconView" firstAttribute="centerX" secondItem="LaunchView" secondAttribute="centerX"/>
                            <constraint firstItem="IconView" firstAttribute="centerY" secondItem="LaunchView" secondAttribute="centerY" constant="-60"/>
                            <constraint firstItem="TitleLabel" firstAttribute="top" secondItem="IconView" secondAttribute="bottom" constant="18"/>
                            <constraint firstItem="TitleLabel" firstAttribute="centerX" secondItem="LaunchView" secondAttribute="centerX"/>
                            <constraint firstItem="SubtitleLabel" firstAttribute="top" secondItem="TitleLabel" secondAttribute="bottom" constant="6"/>
                            <constraint firstItem="SubtitleLabel" firstAttribute="centerX" secondItem="LaunchView" secondAttribute="centerX"/>
                            <constraint firstItem="CopyrightLabel" firstAttribute="centerX" secondItem="LaunchView" secondAttribute="centerX"/>
                            <constraint firstItem="CopyrightLabel" firstAttribute="bottom" secondItem="LaunchView" secondAttribute="bottom" constant="-36"/>
                        </constraints>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="FirstResponder" sceneMemberID="firstResponder"/>
            </objects>
        </scene>
    </scenes>
</document>
